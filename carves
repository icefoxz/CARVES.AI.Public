#!/usr/bin/env bash
set -euo pipefail

repo_root="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
export CARVES_RUNTIME_ROOT="$repo_root"

published_cli="$repo_root/runtime-cli/carves.dll"
if [[ -z "${CARVES_RUNTIME_FORCE_SOURCE:-}" && -f "$published_cli" ]]; then
    exec dotnet "$published_cli" "$@"
fi

project_path="$repo_root/src/CARVES.Runtime.Cli/carves.csproj"
if [[ ! -f "$project_path" ]]; then
    printf "CARVES CLI project is missing from '%s'.\n" "$project_path" >&2
    exit 1
fi

exec dotnet run --project "$project_path" -- "$@"
