{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CARVES Ownership Snapshot",
  "type": "object",
  "required": ["bindings"],
  "properties": {
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["binding_id", "scope", "target_id", "owner_actor_session_id", "owner_kind", "owner_identity", "reason", "claimed_at", "updated_at"],
        "properties": {
          "binding_id": { "type": "string" },
          "scope": { "type": "string" },
          "target_id": { "type": "string" },
          "owner_actor_session_id": { "type": "string" },
          "owner_kind": { "type": "string" },
          "owner_identity": { "type": "string" },
          "reason": { "type": "string" },
          "claimed_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
