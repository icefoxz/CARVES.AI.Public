{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "card_draft",
  "type": "object",
  "required": ["title", "goal", "acceptance"],
  "properties": {
    "card_id": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "acceptance": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_contract": {
      "$ref": "acceptance-contract.schema.json"
    },
    "reality_model": {
      "type": "object",
      "required": [
        "outer_vision",
        "current_solid_scope",
        "next_real_slice",
        "reality_state",
        "solidity_class",
        "proof_target",
        "promotion_gate"
      ],
      "properties": {
        "outer_vision": { "type": "string", "minLength": 1 },
        "current_solid_scope": { "type": "string", "minLength": 1 },
        "next_real_slice": { "type": "string", "minLength": 1 },
        "reality_state": {
          "type": "string",
          "enum": [
            "imagined",
            "bounded",
            "skeleton_proven",
            "compile_proven",
            "slice_proven",
            "reintegration_proven",
            "secondary_consumer_proven",
            "operational"
          ]
        },
        "solidity_class": {
          "type": "string",
          "enum": ["ghost", "proto", "solid"]
        },
        "proof_target": {
          "type": "object",
          "required": ["kind", "description"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "boundary",
                "skeleton",
                "compile",
                "smoke",
                "focused_behavior",
                "reintegration",
                "clean_consumer",
                "secondary_consumer",
                "operational"
              ]
            },
            "description": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "non_goals": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "illusion_risk": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical"]
            },
            "reasons": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        },
        "promotion_gate": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
