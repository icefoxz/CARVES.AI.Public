{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "carves.runtime/contracts/card.schema.json",
  "title": "CARVES Runtime Card Contract",
  "type": "object",
  "required": [
    "version",
    "card_id",
    "title",
    "goal",
    "card_type",
    "priority",
    "scope",
    "acceptance",
    "constraints",
    "dependencies"
  ],
  "properties": {
    "version": { "const": 1 },
    "card_id": { "type": "string" },
    "title": { "type": "string" },
    "goal": { "type": "string" },
    "card_type": { "type": "string" },
    "priority": { "type": "string" },
    "scope": { "type": "array", "items": { "type": "string" } },
    "acceptance": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "acceptance_contract": { "$ref": "acceptance-contract.schema.json" }
  },
  "additionalProperties": false
}
