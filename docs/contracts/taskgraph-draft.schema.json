{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "taskgraph_draft",
  "type": "object",
  "required": ["card_id", "tasks"],
  "properties": {
    "draft_id": { "type": "string" },
    "card_id": { "type": "string", "minLength": 1 },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "task_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string", "minLength": 1 },
          "task_type": { "type": "string", "enum": ["execution", "review", "planning", "meta"] },
          "priority": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "scope": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptance": {
            "type": "array",
            "items": { "type": "string" }
          },
          "constraints": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptance_contract": {
            "$ref": "acceptance-contract.schema.json"
          },
          "proof_target": {
            "type": ["object", "null"],
            "required": ["kind", "description"],
            "properties": {
              "kind": { "type": "string" },
              "description": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
