{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://carves.runtime/contracts/worker-broker-protocol.schema.json",
  "title": "CARVES Runtime Worker Broker Protocol Action",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "protocol_family",
    "surface_status",
    "operation",
    "request_id",
    "host_instance_ref",
    "repo_id",
    "actor",
    "lifecycle_mapping",
    "authority",
    "submitted_at"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "protocol_family": { "const": "worker_broker_protocol" },
    "surface_status": { "const": "proposed_protocol_not_cli" },
    "operation": {
      "type": "string",
      "enum": ["poll", "claim", "heartbeat", "submit", "release"]
    },
    "request_id": { "type": "string" },
    "host_instance_ref": { "type": ["string", "null"] },
    "repo_id": { "type": "string" },
    "task_id": { "type": ["string", "null"], "pattern": "^T-" },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["worker_node_id", "backend_id"],
      "properties": {
        "worker_node_id": { "type": "string" },
        "backend_id": { "type": "string" }
      }
    },
    "dispatch_projection_ref": { "type": ["string", "null"] },
    "lease_id": { "type": ["string", "null"] },
    "result_envelope_ref": { "type": ["string", "null"] },
    "stop_signal": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["present", "reason"],
      "properties": {
        "present": { "type": "boolean" },
        "reason": { "type": ["string", "null"] }
      }
    },
    "lifecycle_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host_action", "truth_owner", "resulting_boundary"],
      "properties": {
        "host_action": {
          "type": "string",
          "enum": [
            "read_dispatch_projection",
            "task_run",
            "lease_heartbeat",
            "task_ingest_result",
            "lease_release"
          ]
        },
        "truth_owner": {
          "type": "string",
          "enum": ["host_scheduler", "worker_lease_store", "result_ingestion", "review_gate"]
        },
        "resulting_boundary": {
          "type": "string",
          "enum": [
            "read_only",
            "leased_execution",
            "lease_observation",
            "review_required",
            "released_or_replan_required"
          ]
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "can_approve_task",
        "can_select_task_without_scheduler",
        "can_mark_completed",
        "can_write_truth"
      ],
      "properties": {
        "can_approve_task": { "const": false },
        "can_select_task_without_scheduler": { "const": false },
        "can_mark_completed": { "const": false },
        "can_write_truth": { "const": false }
      }
    },
    "submitted_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "operation": { "const": "poll" } }, "required": ["operation"] },
      "then": {
        "properties": {
          "task_id": { "type": "null" },
          "lease_id": { "type": "null" },
          "result_envelope_ref": { "type": "null" },
          "lifecycle_mapping": {
            "properties": {
              "host_action": { "const": "read_dispatch_projection" },
              "truth_owner": { "const": "host_scheduler" },
              "resulting_boundary": { "const": "read_only" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "operation": { "const": "claim" } }, "required": ["operation"] },
      "then": {
        "required": ["task_id", "dispatch_projection_ref"],
        "properties": {
          "task_id": { "type": "string", "pattern": "^T-" },
          "lifecycle_mapping": {
            "properties": {
              "host_action": { "const": "task_run" },
              "truth_owner": { "const": "worker_lease_store" },
              "resulting_boundary": { "const": "leased_execution" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "operation": { "const": "heartbeat" } }, "required": ["operation"] },
      "then": {
        "required": ["task_id", "lease_id"],
        "properties": {
          "task_id": { "type": "string", "pattern": "^T-" },
          "lease_id": { "type": "string" },
          "lifecycle_mapping": {
            "properties": {
              "host_action": { "const": "lease_heartbeat" },
              "truth_owner": { "const": "worker_lease_store" },
              "resulting_boundary": { "const": "lease_observation" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "operation": { "const": "submit" } }, "required": ["operation"] },
      "then": {
        "required": ["task_id", "lease_id", "result_envelope_ref"],
        "properties": {
          "task_id": { "type": "string", "pattern": "^T-" },
          "lease_id": { "type": "string" },
          "result_envelope_ref": { "type": "string" },
          "lifecycle_mapping": {
            "properties": {
              "host_action": { "const": "task_ingest_result" },
              "truth_owner": { "const": "result_ingestion" },
              "resulting_boundary": { "const": "review_required" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "operation": { "const": "release" } }, "required": ["operation"] },
      "then": {
        "required": ["task_id", "lease_id"],
        "properties": {
          "task_id": { "type": "string", "pattern": "^T-" },
          "lease_id": { "type": "string" },
          "lifecycle_mapping": {
            "properties": {
              "host_action": { "const": "lease_release" },
              "truth_owner": { "const": "worker_lease_store" },
              "resulting_boundary": { "const": "released_or_replan_required" }
            }
          }
        }
      }
    }
  ]
}
