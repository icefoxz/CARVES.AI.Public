{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CARVES Worktree Runtime Snapshot",
  "type": "object",
  "required": ["records", "pending_rebuilds"],
  "properties": {
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["record_id", "task_id", "worktree_path", "repo_root", "base_commit", "state", "created_at", "updated_at"],
        "properties": {
          "record_id": { "type": "string" },
          "task_id": { "type": "string" },
          "worktree_path": { "type": "string" },
          "repo_root": { "type": "string" },
          "base_commit": { "type": "string" },
          "state": { "type": "string" },
          "quarantine_reason": { "type": ["string", "null"] },
          "rebuilt_from_worktree_path": { "type": ["string", "null"] },
          "worker_run_id": { "type": ["string", "null"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "pending_rebuilds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "source_worktree_path", "reason", "requested_at"],
        "properties": {
          "task_id": { "type": "string" },
          "source_worktree_path": { "type": "string" },
          "reason": { "type": "string" },
          "requested_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
