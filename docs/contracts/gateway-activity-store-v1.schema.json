{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gateway Activity Store v1 Record",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "event",
    "category",
    "timestamp",
    "outcome",
    "fields"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "carves-gateway-activity-store-record.v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event": {
      "type": "string",
      "enum": [
        "gateway-request",
        "gateway-request-failed",
        "gateway-invoke-request",
        "gateway-invoke-response",
        "gateway-invoke-accepted",
        "gateway-accepted-operation-running",
        "gateway-accepted-operation-completed",
        "gateway-accepted-operation-failed",
        "gateway-session-create-request",
        "gateway-session-create-response",
        "gateway-session-message-request",
        "gateway-session-message-response",
        "gateway-session-events-request",
        "gateway-session-events-response",
        "gateway-session-read-request",
        "gateway-session-read-response",
        "gateway-session-operation-approve-request",
        "gateway-session-operation-approve-response",
        "gateway-session-operation-reject-request",
        "gateway-session-operation-reject-response",
        "gateway-session-operation-replan-request",
        "gateway-session-operation-replan-response",
        "gateway-session-operation-read-request",
        "gateway-session-operation-read-response",
        "gateway-route-not-found"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "gateway_request",
        "cli_invoke",
        "rest_request",
        "session_message",
        "operation_feedback",
        "route_not_found",
        "request",
        "feedback"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "request_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "method": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "route": {
      "type": "string"
    },
    "status": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "outcome": {
      "type": "string",
      "enum": [
        "received",
        "completed",
        "accepted",
        "failed",
        "not_found"
      ]
    },
    "session_id": {
      "type": "string"
    },
    "message_id": {
      "type": "string"
    },
    "operation_id": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "error_code": {
      "type": "string"
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
