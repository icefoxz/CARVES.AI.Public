{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://carves.runtime/contracts/failure-report.schema.json",
  "title": "FailureReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "timestamp",
    "repo",
    "objective",
    "result",
    "failure",
    "attribution"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": {
      "type": "string",
      "pattern": "^FAIL-[0-9]{8}-[0-9]{6}-[0-9]{3,}$"
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "cardId": { "type": ["string", "null"] },
    "taskId": { "type": ["string", "null"] },
    "repo": { "type": "string" },
    "branch": { "type": "string" },
    "worktree": { "type": ["string", "null"] },
    "provider": { "type": ["string", "null"] },
    "modelProfile": { "type": ["string", "null"] },
    "objective": { "type": "string" },
    "inputSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filesInvolved": {
          "type": "array",
          "items": { "type": "string" }
        },
        "estimatedScope": { "type": "string" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "patchFiles": { "type": "integer", "minimum": 0 },
        "patchLines": { "type": "integer", "minimum": 0 },
        "commandsRun": {
          "type": "array",
          "items": { "type": "string" }
        },
        "durationSeconds": { "type": "integer", "minimum": 0 }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "stopReason"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["failed", "blocked", "rejected"]
        },
        "stopReason": { "type": "string" }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "message"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "build_failure",
            "test_regression",
            "scope_drift",
            "infinite_patch_loop",
            "wrong_file_touched",
            "contract_violation",
            "dependency_misread",
            "incomplete_task",
            "review_rejected",
            "environment_failure",
            "timeout",
            "unknown"
          ]
        },
        "message": { "type": "string" },
        "details": { "type": ["string", "null"] },
        "stackTrace": { "type": ["string", "null"] }
      }
    },
    "attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer", "confidence"],
      "properties": {
        "layer": {
          "type": "string",
          "enum": ["planner", "worker", "task", "provider", "environment"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "notes": { "type": ["string", "null"] }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "rejected": { "type": "boolean" },
        "reason": { "type": ["string", "null"] }
      }
    },
    "contextSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state": { "type": "string" },
        "previousFailures": { "type": "integer", "minimum": 0 },
        "retryCount": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
