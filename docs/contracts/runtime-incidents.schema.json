{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CARVES Runtime Incident Timeline",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["incident_id", "incident_type", "repo_id", "actor_kind", "reason_code", "summary", "occurred_at"],
    "properties": {
      "incident_id": { "type": "string" },
      "incident_type": { "type": "string" },
      "repo_id": { "type": "string" },
      "task_id": { "type": ["string", "null"] },
      "run_id": { "type": ["string", "null"] },
      "backend_id": { "type": ["string", "null"] },
      "provider_id": { "type": ["string", "null"] },
      "permission_request_id": { "type": ["string", "null"] },
      "failure_kind": { "type": "string" },
      "recovery_action": { "type": "string" },
      "actor_kind": { "type": "string" },
      "actor_identity": { "type": "string" },
      "reason_code": { "type": "string" },
      "summary": { "type": "string" },
      "consequence_summary": { "type": "string" },
      "reference_id": { "type": ["string", "null"] },
      "occurred_at": { "type": "string", "format": "date-time" }
    }
  }
}
