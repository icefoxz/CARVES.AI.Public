{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CARVES.Runtime Opportunity Snapshot",
  "type": "object",
  "required": ["version", "generated_at", "items"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "opportunity_id",
          "source",
          "fingerprint",
          "title",
          "description",
          "reason",
          "severity",
          "confidence",
          "status",
          "related_files",
          "materialized_task_ids",
          "first_detected_at",
          "last_detected_at",
          "updated_at"
        ],
        "properties": {
          "schema_version": {
            "type": "integer",
            "const": 1
          },
          "opportunity_id": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "fingerprint": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          },
          "status": {
            "type": "string"
          },
          "related_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "materialized_task_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_evaluation_reason": {
            "type": ["string", "null"]
          },
          "first_detected_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_detected_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
