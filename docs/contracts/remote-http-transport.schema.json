{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Remote HTTP Transport Contract",
  "type": "object",
  "properties": {
    "method": { "type": "string" },
    "url": { "type": "string" },
    "content_type": { "type": "string" },
    "timeout_seconds": { "type": "integer" },
    "max_retries": { "type": "integer" },
    "headers": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "required": ["method", "url"]
}
