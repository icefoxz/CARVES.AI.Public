      "strict": "block",
      "normal": "block",
      "search": "candidate_only",
      "release": "blocker"
    },
    {
      "failure_code": "conflicting_canonical_facts",
      "strict": "block",
      "normal": "block",
      "search": "surface_conflict",
      "release": "blocker"
    }
  ]
