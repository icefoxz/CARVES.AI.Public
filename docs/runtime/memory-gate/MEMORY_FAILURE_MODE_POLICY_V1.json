      "search": "exclude_disputed",
      "release": "blocker_if_unresolved"
    },
    {
      "failure_code": "active_view_build_failed",
      "strict": "block",
      "normal": "degraded",
      "search": "fallback_lexical_only",
      "release": "blocker_for_writeback"
