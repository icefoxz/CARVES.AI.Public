  "phase_rules": [
    {
      "phase_id": "planning",
      "plain_meaning": "Decide scope and next safe action without loading broad pack payload.",
      "first_read_layers": [
        "identity_header",
        "review_posture",
        "budget_readback"
      ],
      "allowed_next_layers": [
        "summary"
      ],
      "full_expansion_default": false,
      "expansion_requires_task_relevant_reason": true,
      "required_expansion_reason_kinds": [
        "acceptance_dependency_unclear",
        "scope_boundary_conflict",
        "candidate_gate_mismatch"
      ],
      "preserve_expansion_refs": true,
      "must_not": [
        "do_not_read_all_pack_material_for_brainstorming",
        "do_not_replace_card_acceptance_with_pack_summary"
      ]
    },
    {
      "phase_id": "implementation",
      "plain_meaning": "Use pack material only when it points to files, constraints, or evidence needed for the current change.",
      "first_read_layers": [
        "identity_header",
        "review_posture",
        "budget_readback",
        "summary"
      ],
      "allowed_next_layers": [
        "source_excerpt"
      ],
      "full_expansion_default": false,
      "expansion_requires_task_relevant_reason": true,
      "required_expansion_reason_kinds": [
        "target_file_scope_requires_source_excerpt",
        "acceptance_evidence_requires_source_excerpt",
        "budget_readback_names_omitted_required_material"
      ],
      "preserve_expansion_refs": true,
      "must_not": [
        "do_not_expand_unrelated_pack_families",
        "do_not_use_pack_summary_as_source_truth"
      ]
    },
    {
      "phase_id": "review",
      "plain_meaning": "Check changed behavior against acceptance and evidence without treating pack prose as proof.",
      "first_read_layers": [
        "identity_header",
        "review_posture",
        "budget_readback",
        "source_excerpt"
      ],
      "allowed_next_layers": [
        "summary"
      ],
      "full_expansion_default": false,
      "expansion_requires_task_relevant_reason": true,
      "required_expansion_reason_kinds": [
        "review_evidence_gap",
        "changed_file_reference_missing",
        "non_claim_conflict"
      ],
      "preserve_expansion_refs": true,
      "must_not": [
        "do_not_accept_fluent_pack_text_as_validation",
        "do_not_expand_full_pack_when_changed_files_are_enough"
      ]
    },
    {
      "phase_id": "cleanup",
      "plain_meaning": "Remove or simplify only with identity and ownership clear; avoid broad history reads.",
      "first_read_layers": [
        "identity_header",
        "review_posture"
      ],
      "allowed_next_layers": [
        "budget_readback",
        "summary"
      ],
      "full_expansion_default": false,
      "expansion_requires_task_relevant_reason": true,
      "required_expansion_reason_kinds": [
        "ownership_boundary_unclear",
        "stale_pointer_cleanup_requires_source",
        "non_claim_cleanup_risk"
      ],
      "preserve_expansion_refs": true,
      "must_not": [
        "do_not_delete_truth_because_pack_projection_omits_it",
        "do_not_cleanup_by_reading_all_archives"
      ]
    },
    {
      "phase_id": "audit",
      "plain_meaning": "Sample evidence and blockers through pointers before deciding whether deeper proof material is needed.",
      "first_read_layers": [
        "identity_header",
        "review_posture",
        "budget_readback",
        "summary"
      ],
      "allowed_next_layers": [
        "source_excerpt"
      ],
      "full_expansion_default": false,
      "expansion_requires_task_relevant_reason": true,
      "required_expansion_reason_kinds": [
        "sampled_evidence_mismatch",
        "completion_gate_requires_deeper_evidence",
        "manual_review_scope_requires_full_material"
      ],
      "preserve_expansion_refs": true,
      "must_not": [
        "do_not_make_full_pack_audit_default",
        "do_not_turn_audit_sampling_into_second_registry"
      ]
    }
