      "if_any": [
        "DERIVED_ARTIFACT_TOUCHED"
      ],
      "force": {
        "intake_route": "artifact",
        "execution_level": "none",
        "eligibility": "blocked"
      }
    },
    {
      "rank": 5,
      "if_any": [
        "SCOPE_DOMAIN_MISMATCH"
      ],
      "force": {
        "eligibility": "blocked"
      }
    },
    {
      "rank": 6,
      "if_all": [
        "planned_paths_known",
        "worktree_clean_or_owned",
        "no_high_risk_reason_codes",
        "observed_evidence_available"
      ],
      "allow": {
        "intake_route": "execution",
        "execution_level": "direct_lightweight",
        "eligibility": "allowed"
      }
    }
  ],
  "direct_lightweight_permissions": {
    "file_read_allowed": true,
    "file_write_allowed": true,
    "worker_allowed": false,
    "truth_write_allowed": false,
    "submit_allowed": false,
    "artifact_write_allowed": false,
    "completion_allowed": false
  },
  "host_unverified_blocks": [
    "truth_write_allowed",
    "submit_allowed",
    "artifact_write_allowed",
    "completion_allowed"
  ],
  "bootstrap_postflight": {
    "required_after_file_creation": true,
    "checks": [
      "actual_diff_paths_subset_of_bootstrap_allowed_paths",
      "policy_status_is_proposed",
      "runtime_authority_is_false",
      "agent_rules_path_ends_with_CANDIDATE.md",
      "agent_rules_first_line_declares_not_active_not_truth",
      "no_AGENTS_md_change",
      "no_initialization_spec_change",
      "no_ai_change_except_host_routed_governance_state",
      "no_src_change",
      "no_tests_fixtures_change",
      "no_artifacts_change"
    ],
    "on_failure": {
      "action": "quarantine",
      "submit_allowed": false,
      "activation_allowed": false,
      "next_route": "recovery"
    }
  },
  "postflight_failure": {
    "action": "quarantine",
    "permissions_after_failure": {
      "submit_allowed": false,
      "truth_write_allowed": false,
      "artifact_write_allowed": false,
      "completion_allowed": false
    },
    "required_output": [
      "actual_diff_inventory",
      "boundary_violation_reason",
      "next_route"
    ]
  }
}
