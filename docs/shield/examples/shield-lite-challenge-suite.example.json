      "title": "Protected path edit is blocked",
      "intent": "Confirm Guard evidence treats protected paths as fail-closed local governance boundaries.",
      "fixture": {
        "summary": "A patch attempts to edit .git/config and .env without an approved exception.",
        "mutations": [
          {
            "artifact": "guard_decision",
            "operation": "set protected path change under .git/ and .env",
            "description": "The local guard decision should be block, not review or allow."
          }
        ]
      },
      "expected_local_decision_posture": {
        "decision": "block",
        "shield_lite_band_ceiling": "critical",
        "reason_codes": [
          "protected_path_violation"
